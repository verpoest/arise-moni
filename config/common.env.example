# ARISE Monitoring Configuration Template
# Copy this to common.env and fill in real values

# Paths
DATA_DIR="/path/to/data"
OUTPUT_DIR="/path/to/output"
LOG_DIR="/home/user/arise_monitor/logs"
WEB_DIR="/home/user/arise_monitor/web"

# Settings
EMAIL_RECIPIENTS="user@example.com,other@example.com"
DISK_THRESHOLD_PERCENT=90

# Slack Incoming Webhook URL (optional — leave empty to disable Slack alerts)
SLACK_WEBHOOK_URL=""

# Network topology IPs (per station)
# Each station is reached via: Server -> WR-LEN switch -> TAXI DAQ
# WR-LEN switch IPs
WRLEN_IP_1="192.168.1.x"
WRLEN_IP_2="192.168.1.x"
# ...

# TAXI DAQ computer IPs
TAXI_IP_1="192.168.1.x"
TAXI_IP_2="192.168.1.x"
# ...

# ARISE CHK Boxes (microcontroller IPs, one per station)
ARISE_CHK_ST1_IP="192.168.1.x"
ARISE_CHK_ST2_IP="192.168.1.x"
# ...

# Local destination for storing CHK sensor data
ARISE_CHK_DATA_DIR="/path/to/chk_data"