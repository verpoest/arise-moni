# ARISE Monitoring Configuration Template
# Copy this to common.env and fill in real values

# Paths
DATA_DIR="/path/to/data"
OUTPUT_DIR="/path/to/output"
LOG_DIR="/home/user/arise_monitor/logs"
WEB_DIR="/home/user/arise_monitor/web"

# Settings
EMAIL_RECIPIENTS="user@example.com,other@example.com"
DISK_THRESHOLD_PERCENT=90

# Slack Incoming Webhook URL (optional — leave empty to disable Slack alerts)
SLACK_WEBHOOK_URL=""

# Station IPs
STATION_IP_1="192.168.1.x"
STATION_IP_2="192.168.1.x"
# ...